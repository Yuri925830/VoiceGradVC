import torch
import torch.nn.functional as F
import numpy as np
import soundfile as sf
import math

from models.model_practice_en import UNet 

class VoiceGradInference:
    def __init__(self, model_path, device="cuda" if torch.cuda.is_available() else "cpu"):
        self.device = device
        
        # Initialize the target model with architecture specifications from project notes
        # x_channels=80 (Mel-scale channels), cond_channels=144 (BNF bottleneck dimensions)
        self.model = UNet(x_channels=80, cond_channels=144, num_speakers=4).to(self.device)
        
        # Load the trained model weights securely across CPU or GPU devices
        self.model.load_state_dict(torch.load(model_path, map_location=self.device))
        self.model.eval() # Explicitly set model to evaluation mode to disable dropout/batchnorm updates
        
        # Global Mel-spectrogram normalization parameters extracted from dataset baselines
        # These must match training configurations to prevent mathematical divergence
        self.mel_mean = 0.0  
        self.mel_std = 1.0   

    def preprocess_features(self, raw_mel, raw_bnf):
        # Convert raw numpy arrays to PyTorch Float Tensors and append a Batch Dimension [B=1, C, T]
        mel = torch.FloatTensor(raw_mel).unsqueeze(0).to(self.device)
        bnf = torch.FloatTensor(raw_bnf).unsqueeze(0).to(self.device)
        
        # Apply channel-wise Mel normalization to scale features uniformly around 0
        # Mathematical formula: mel_normalized = (raw_mel - mean) / standard_deviation
        mel_normalized = (mel - self.mel_mean) / self.mel_std
        
        # Address the 1.6x sampling rate mismatch between Mel (62.5 fps) and BNF (100.0 fps)
        # We fetch the exact time length of the Mel tensor as the golden reference target
        target_time_length = mel_normalized.size(-1) 
        
        # Perform 1D linear interpolation to stretch or shrink the BNF time axis to match the Mel axis
        bnf_resampled = F.interpolate(bnf, size=target_time_length, mode='linear', align_corners=False)
        
        return mel_normalized, bnf_resampled

    def get_cosine_schedule_values(self, total_steps=20, s=0.008):
        steps = total_steps + 1
        x = torch.linspace(0, total_steps, steps, dtype=torch.float64)
        
        # Calculate alpha_bar (alphas_cumprod) array sequence using the cosine formula rule
        alphas_cumprod = torch.cos(((x / total_steps) + s) / (1 + s) * math.pi / 2) ** 2
        alphas_cumprod = alphas_cumprod / alphas_cumprod[0]
        
        # Extrapolate individual beta values bounded within maximum clip threshold of 0.999
        betas = 1 - (alphas_cumprod[1:] / alphas_cumprod[:-1])
        betas = torch.clip(betas, 0.0001, 0.999)
        
        # Recompute final alphas and cumulative variance components matching his exact tensor variables
        alphas = 1.0 - betas
        alphas_cumprod = torch.cumprod(alphas, dim=0)
        
        return betas.to(self.device), alphas.to(self.device), alphas_cumprod.to(self.device)

    @torch.no_grad()
    def voice_conversion_loop(self, raw_mel, raw_bnf, target_spk_id, total_steps=20):
        # Extract normalized features and time-aligned linguistic conditions
        mel_normalized, bnf_resampled = self.preprocess_features(raw_mel, raw_bnf)
        
        # Initialize inference from pure Gaussian Noise (x_T) matching the exact dimensions of the target Mel
        x_t = torch.randn_like(mel_normalized).to(self.device)
        
        # Extract the exact matching Cosine hyperparameter schedules 
        betas, alphas, alphas_cumprod = self.get_cosine_schedule_values(total_steps=total_steps)
        
        print(f"Beginning Cosine Scheduled Reverse Diffusion via Annealed Langevin Dynamics ({total_steps} steps)...")
        
        # Iteratively remove noise stepping backward from T-1 down to 0
        for t in reversed(range(total_steps)):
            # Package current timestep as a PyTorch Long Tensor tensor [Batch size = 1]
            timestep_tensor = torch.full((1,), t, device=self.device, dtype=torch.long)
            
            # Package target speaker identity constraint into a Long Tensor [Batch size = 1]
            speaker_tensor = torch.tensor([target_spk_id], device=self.device, dtype=torch.long)
            
            # Query the U-Net score approximator to predict noise added at current step t
            predicted_noise = self.model(x_t, timestep_tensor, speaker_tensor, bnf_resampled)
            
            # Isolate schedule hyper-parameters for current discrete step t
            beta_t = betas[t]
            alpha_t = alphas[t]
            alpha_cumprod_t = alphas_cumprod[t]
            
            # Compute score mapping coefficient to extract clean data distribution direction
            noise_coef = (1.0 - alpha_t) / torch.sqrt(1.0 - alpha_cumprod_t)
            
            # Denoising Equation: Extrapolate mean of the distribution for the prior step x_{t-1}
            mean = (1.0 / torch.sqrt(alpha_t)) * (x_t - noise_coef * predicted_noise)
            
            # Inject stochastic noise variance back for numerical generation stability (for all steps except t=0)
            if t > 0:
                noise = torch.randn_like(x_t).to(self.device)
                sigma_t = torch.sqrt(beta_t) 
                x_t = mean + sigma_t * noise
            else:
                # Terminal step evaluation: set sample explicitly to calculated mean distribution
                x_t = mean
                
        print("Reverse Diffusion inference sequence complete.")
        
        # Denormalize output tensor to recover original physical Mel-spectrogram bounds
        converted_mel = (x_t * self.mel_std) + self.mel_mean
        
        # Remove batch tracking dimension and return clean NumPy matrix array [80, Time]
        return converted_mel.squeeze(0).cpu().numpy()

    def save_to_waveform(self, mel_spectrogram, output_path, vocoder_model=None):
        print(f"Directing output synthesis to: {output_path}")
        
        if vocoder_model is None:
            # Code execution safeguard: builds mock baseline signal if team vocoder is unlinked
            print("Notice: Vocoder module unlinked. Instantiating reference placeholder wave.")
            mock_waveform = np.sin(2 * np.pi * 440 * np.arange(16000 * 2) / 16000)
            sf.write(output_path, mock_waveform, 16000)
        else:
            # Future Integration Hook: Execute when Neural Vocoder (e.g., HiFi-GAN) is linked
            pass
